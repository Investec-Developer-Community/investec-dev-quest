{
  "name": "investec-developer-game",
  "private": true,
  "version": "1.7.0",
  "description": "A local-first developer learning game for the Investec developer community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Investec-Developer-Community/investec-dev-quest.git"
  },
  "bugs": {
    "url": "https://github.com/Investec-Developer-Community/investec-dev-quest/issues"
  },
  "homepage": "https://github.com/Investec-Developer-Community/investec-dev-quest#readme",
  "packageManager": "pnpm@9.12.3",
  "keywords": [
    "investec",
    "developer-game",
    "security",
    "fintech",
    "learning"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm validate",
    "test:watch": "vitest",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "game": "node scripts/game.mjs",
    "game:strict": "pnpm --filter @investec-game/shared build && pnpm --filter @investec-game/cli run dev",
    "validate": "node scripts/validate-levels.mjs",
    "create-level": "node scripts/create-level.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.41",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.46.2",
    "vitest": "^2.1.0"
  }
}
